# Database
POSTGRES_DB=futbol_olvidable
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/futbol_olvidable

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# Upload / WebP
UPLOAD_PATH=/app/uploads
UPLOAD_MAX_SIZE_MB=5
UPLOAD_WEBP_QUALITY=80
UPLOAD_MAX_WIDTH=800
UPLOAD_MAX_HEIGHT=800

# API
PORT=3000
NODE_ENV=development
RUN_SEED=true

# OAuth Google (futuro — no implementar aún)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://futbol-olvidable.archsys.com/api/auth/google/callback

# SSL (solo prod)
ENABLE_SSL=false
DOMAIN=futbol-olvidable.archsys.com
CERTBOT_EMAIL=
